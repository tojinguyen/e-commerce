# Routes external traffic to the services. Install the NGINX Ingress controller
# first (see `make cluster-up`). On kind, access via http://localhost/.
#
# No path rewrite: services mount their routes at the full /api/v1/<resource> path,
# so the incoming path is forwarded unchanged.
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ecommerce-gateway
  namespace: ecommerce
spec:
  ingressClassName: nginx
  rules:
    - http:
        paths:
          - path: /api/v1/products
            pathType: Prefix
            backend:
              service:
                name: product-service
                port:
                  number: 8080
          - path: /api/v1/carts
            pathType: Prefix
            backend:
              service:
                name: cart-service
                port:
                  number: 8081
          - path: /api/v1/orders
            pathType: Prefix
            backend:
              service:
                name: order-service
                port:
                  number: 8082
</file>

<file path="deploy/k8s/ingress/20-swagger-ingress.yaml">
# Exposes the Swagger UI for each service at a unique external path.
#
# Rewrite rule strips the service-name segment before forwarding:
#   /swagger/product/(...) → /swagger/$1 on product-service
#   /swagger/cart/(...)    → /swagger/$1 on cart-service
#   /swagger/order/(...)   → /swagger/$1 on order-service
#
# Access via:
#   http://localhost/swagger/product/index.html
#   http://localhost/swagger/cart/index.html
#   http://localhost/swagger/order/index.html
#
# Separate Ingress objects are required because rewrite-target is a
# per-Ingress annotation and cannot differ between paths in one object.
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: product-swagger
  namespace: ecommerce
  annotations:
    nginx.ingress.kubernetes.io/use-regex: "true"
    nginx.ingress.kubernetes.io/rewrite-target: /swagger/$1
spec:
  ingressClassName: nginx
  rules:
    - http:
        paths:
          - path: /swagger/product/(.*)
            pathType: ImplementationSpecific
            backend:
              service:
                name: product-service
                port:
                  number: 8080
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: cart-swagger
  namespace: ecommerce
  annotations:
    nginx.ingress.kubernetes.io/use-regex: "true"
    nginx.ingress.kubernetes.io/rewrite-target: /swagger/$1
spec:
  ingressClassName: nginx
  rules:
    - http:
        paths:
          - path: /swagger/cart/(.*)
            pathType: ImplementationSpecific
            backend:
              service:
                name: cart-service
                port:
                  number: 8081
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: order-swagger
  namespace: ecommerce
  annotations:
    nginx.ingress.kubernetes.io/use-regex: "true"
    nginx.ingress.kubernetes.io/rewrite-target: /swagger/$1
spec:
  ingressClassName: nginx
  rules:
    - http:
        paths:
          - path: /swagger/order/(.*)
            pathType: ImplementationSpecific
            backend:
