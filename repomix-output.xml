kind: Service
metadata:
  name: kafka-connect
  namespace: ecommerce
spec:
  selector:
    app: kafka-connect
  ports:
    - port: 8083
      targetPort: 8083
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: kafka-connect
  namespace: ecommerce
spec:
  replicas: 1
  selector:
    matchLabels:
