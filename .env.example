# ---- Shared / local development environment ----
# Copy to .env for local (non-k8s) runs. In Kubernetes these values come from
# ConfigMaps/Secrets in deploy/k8s.

# ---- Product Service (PostgreSQL + Elasticsearch) ----
PRODUCT_HTTP_PORT=8080
PRODUCT_PG_DSN=host=localhost port=5433 user=product password=product dbname=product_db sslmode=disable
PRODUCT_ES_ADDRESS=http://localhost:9200

# ---- Cart Service (MongoDB) ----
CART_HTTP_PORT=8081
CART_MONGO_URI=mongodb://localhost:27017
CART_MONGO_DB=cart_db

# ---- Order Service (PostgreSQL + Temporal) ----
ORDER_HTTP_PORT=8082
ORDER_PG_DSN=host=localhost port=5434 user=order password=order dbname=order_db sslmode=disable
TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=order-task-queue

# ---- Observability (OpenTelemetry / OTLP) ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_ENVIRONMENT=local
LOG_LEVEL=info
